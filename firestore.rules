rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - totalPoints: number (required)
    //
    // Collection: matches
    // Document ID: matchId
    // Fields:
    //   - id: string (required)
    //   - teamA: string (required)
    //   - teamB: string (required)
    //   - group: string (optional)
    //   - date: string (required)
    //   - location: string (optional)
    //   - scoreA: number (optional)
    //   - scoreB: number (optional)
    //   - status: string (required, enum: ["pending", "finished"])
    //
    // Collection: bets
    // Document ID: userId_matchId
    // Fields:
    //   - userId: string (required)
    //   - matchId: string (required)
    //   - scoreA: number (required)
    //   - scoreB: number (required)
    //   - pointsEarned: number (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "alexblbn@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'totalPoints']) &&
             data.uid is string &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.totalPoints is number &&
             (!('role' in data) || data.role in ['admin', 'user']);
    }

    function isValidMatch(data) {
      return data.keys().hasAll(['id', 'teamA', 'teamB', 'date', 'status']) &&
             data.id is string &&
             data.teamA is string && data.teamA.size() > 0 &&
             data.teamB is string && data.teamB.size() > 0 &&
             data.date is string &&
             data.status in ['pending', 'finished'];
    }

    function isValidBet(data) {
      return data.keys().hasAll(['userId', 'matchId', 'scoreA', 'scoreB']) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.matchId is string &&
             data.scoreA is number && data.scoreA >= 0 &&
             data.scoreB is number && data.scoreB >= 0;
    }

    function isValidCallup(data) {
      return data.keys().hasAll(['userId', 'players', 'updatedAt']) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.players is map &&
             data.updatedAt is string &&
             (!('pointsAwarded' in data) || data.pointsAwarded is number);
    }

    function isValidOfficialCallup(data) {
      return data.keys().hasAll(['players', 'updatedAt', 'isFinalized']) &&
             data.players is list &&
             data.updatedAt is string &&
             data.isFinalized is bool;
    }

    function isNotBanned() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return !('isBanned' in userDoc) || userDoc.isBanned == false;
    }

    function isNotDeleted() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return !('isDeleted' in userDoc) || userDoc.isDeleted == false;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.totalPoints == 0;
      allow update: if (isOwner(userId) && isNotBanned() && isNotDeleted() && isValidUser(request.resource.data) && request.resource.data.totalPoints == resource.data.totalPoints) || isAdmin();
      allow delete: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bets/{betId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId) && isValidBet(request.resource.data);
      allow update: if (isAuthenticated() && isOwner(resource.data.userId) && isValidBet(request.resource.data) && !('pointsEarned' in request.resource.data)) || isAdmin();
      allow delete: if isAdmin();
    }

    match /callups/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidCallup(request.resource.data);
      allow update: if (isOwner(userId) && isValidCallup(request.resource.data) && !('pointsAwarded' in request.resource.data)) || isAdmin();
      allow delete: if isAdmin();
    }

    match /system/stats {
      allow read: if isAdmin();
      allow create, update: if isAuthenticated();
    }

    match /config/official_callup {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}

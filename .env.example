# --- CONEXÃO COM O BANCO DE DADOS POSTGRESQL ---
# URL de conexão com o banco de dados PostgreSQL. Exemplo: postgresql://postgres:senha@host:5432/palpitao
DATABASE_URL="postgresql://postgres:senha@host:5432/palpitao"

# --- SEGURANÇA E AUTENTICAÇÃO JWT ---
# Chave secreta de alta entropia para assinar e validar os tokens JWT de sessão dos usuários.
JWT_SECRET="insira-uma-chave-secreta-e-segura-aqui"

# --- CONFIGURAÇÃO DO ADMINISTRADOR DO SISTEMA ---
# E-mail que receberá permissões administrativas ("admin") automaticamente ao se registrar.
ADMIN_EMAIL="alexblbn@gmail.com"

# --- INTELIGÊNCIA ARTIFICIAL (GEMINI API) ---
# Sua chave de API do Gemini para sincronizar os placares oficiais automaticamente usando IA.
GEMINI_API_KEY="AIzaSy..."

# --- CONFIGURAÇÃO DE AMBIENTE ---
# Indica se o aplicativo está sendo executado em desenvolvimento ou produção.
NODE_ENV="production"
